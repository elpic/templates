# Generated from setup.bp — do not edit directly.
# Regenerate: blueprint render setup.bp --template . --output .github/workflows --var BLUEPRINT_FILE={{ var "BLUEPRINT_FILE" }} --var TEMPLATE={{ var "TEMPLATE" }} --var AGAINST={{ var "AGAINST" }}
# Check drift:  blueprint check setup.bp --template . --against .github/workflows --var BLUEPRINT_FILE={{ var "BLUEPRINT_FILE" }} --var TEMPLATE={{ var "TEMPLATE" }} --var AGAINST={{ var "AGAINST" }}

name: Blueprint Drift Check

on:
  pull_request:
    branches:
      - {{ default "MAIN_BRANCH" "main" }}

permissions:
  pull-requests: write
  contents: read

jobs:
  blueprint-check:
    name: Blueprint Drift Check
    runs-on: {{ default "RUNNER" "ubuntu-latest" }}
    timeout-minutes: {{ default "TIMEOUT_MINUTES" "5" }}
    steps:
      - uses: elpic/actions/github/blueprint-check@{{ default "ACTIONS_VERSION" "v1" }}
        with:
          blueprint-file: {{ var "BLUEPRINT_FILE" }}
          template: {{ var "TEMPLATE" }}
          against: {{ var "AGAINST" }}
