# Check drift:  blueprint check setup.bp --template . --against .github/workflows \
#   --var APP_NAME={{ var "APP_NAME" }} --var PYPI_PROJECT_NAME={{ var "PYPI_PROJECT_NAME" }}

# Publish — build, version, and publish {{ var "APP_NAME" }} to {{ default "REGISTRY" "pypi" }}.
#
# Triggers:
#   push to {{ default "MAIN_BRANCH" "main" }} — Release Please auto-versions
#   workflow_dispatch                    — manually publish a specific version
#
# Supported registries:
#   pypi   — Trusted Publishing (OIDC), no tokens needed
#   github — GitHub Packages, uses built-in GITHUB_TOKEN
#   jfrog  — JFrog Artifactory, requires secrets (JFROG_URL, JFROG_USER, JFROG_TOKEN)

name: Publish

on:
  push:
    branches:
      - {{ default "MAIN_BRANCH" "main" }}
  workflow_dispatch:
    inputs:
      version:
        description: "Version to publish (e.g. 0.1.0). Leave empty for normal dev/stable flow."
        required: false

permissions:
  contents: write
  pull-requests: write
  id-token: write

jobs:

  release-please:
    if: github.event_name != 'workflow_dispatch'
    runs-on: {{ default "RUNNER" "ubuntu-latest" }}
    outputs:
      release_created: ${{ "{{" }} steps.release.outputs.release_created {{ "}}" }}
      tag_name:       ${{ "{{" }} steps.release.outputs.tag_name {{ "}}" }}
    steps:
      - uses: googleapis/release-please-action@v4
        id: release
        with:
          token: ${{ "{{" }} secrets.GITHUB_TOKEN {{ "}}" }}
          config-file: {{ default "RELEASE_PLEASE_CONFIG" "release-please-config.json" }}

  build:
    if: always()
    needs: [release-please]
    runs-on: {{ default "RUNNER" "ubuntu-latest" }}
    timeout-minutes: {{ default "TIMEOUT_MINUTES" "10" }}
    steps:
      - uses: elpic/actions/delivery/python/build@v1
        with:
          app-name: {{ var "APP_NAME" }}
          build-task: {{ default "BUILD_TASK" "build" }}
          pypi-package-dir: {{ default "PACKAGE_DIR" "dist" }}

  publish:
    if: always()
    needs: [release-please, build]
    runs-on: {{ default "RUNNER" "ubuntu-latest" }}
    timeout-minutes: {{ default "TIMEOUT_MINUTES" "10" }}
    environment:
      name: {{ default "ENVIRONMENT" (default "REGISTRY" "pypi") }}
      url: https://pypi.org/project/{{ var "PYPI_PROJECT_NAME" }}/
    steps:
      - uses: elpic/actions/delivery/python/publish@v1
        with:
          app-name: {{ var "APP_NAME" }}
          registry: {{ default "REGISTRY" "pypi" }}
          packages-dir: {{ default "PACKAGE_DIR" "dist" }}
          jfrog-url: ${{ "{{" }} secrets.JFROG_URL {{ "}}" }}
          jfrog-user: ${{ "{{" }} secrets.JFROG_USER {{ "}}" }}
          jfrog-token: ${{ "{{" }} secrets.JFROG_TOKEN {{ "}}" }}
