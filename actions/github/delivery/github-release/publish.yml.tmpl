# Generated from setup.bp — do not edit directly.
# Regenerate: blueprint render setup.bp --template . --output .github/workflows --var APP_NAME={{ var "APP_NAME" }}
# Check drift:  blueprint check setup.bp --template . --against .github/workflows --var APP_NAME={{ var "APP_NAME" }}

# Publish — build and create a GitHub Release for {{ var "APP_NAME" }}.
#
# Triggers:
#   push to {{ default "MAIN_BRANCH" "main" }} — Release Please auto-versions
#   workflow_dispatch                    — manually create a release for a specific version

name: Publish

on:
  push:
    branches:
      - {{ default "MAIN_BRANCH" "main" }}
  workflow_dispatch:
    inputs:
      version:
        description: "Version to release (e.g. 0.1.0). Leave empty for normal dev/stable flow."
        required: false

permissions:
  contents: write
  pull-requests: write

jobs:

  release-please:
    if: github.event_name != 'workflow_dispatch'
    runs-on: {{ default "RUNNER" "ubuntu-latest" }}
    outputs:
      release_created: ${{ "{{" }} steps.release.outputs.release_created {{ "}}" }}
      tag_name:       ${{ "{{" }} steps.release.outputs.tag_name {{ "}}" }}
    steps:
      - uses: googleapis/release-please-action@v4
        id: release
        with:
          token: ${{ "{{" }} secrets.GITHUB_TOKEN {{ "}}" }}
          config-file: {{ default "RELEASE_PLEASE_CONFIG" "release-please-config.json" }}

  build:
    if: always()
    needs: [release-please]
    runs-on: {{ default "RUNNER" "ubuntu-latest" }}
    timeout-minutes: {{ default "TIMEOUT_MINUTES" "10" }}
    steps:
      - uses: elpic/actions/delivery/github-release/build@v1
        with:
          app-name: {{ var "APP_NAME" }}
          build-task: {{ default "BUILD_TASK" "build" }}

  publish:
    if: always()
    needs: [release-please, build]
    runs-on: {{ default "RUNNER" "ubuntu-latest" }}
    timeout-minutes: {{ default "TIMEOUT_MINUTES" "10" }}
    steps:
      - uses: elpic/actions/delivery/github-release/publish@v1
        with:
          app-name: {{ var "APP_NAME" }}
          build-output: {{ default "BUILD_OUTPUT" "dist" }}
