# Generated from setup.bp — do not edit directly.
# Regenerate: blueprint render setup.bp --template . --output .github/workflows --var APP_NAME={{ var "APP_NAME" }}
# Check drift:  blueprint check setup.bp --template . --against .github/workflows --var APP_NAME={{ var "APP_NAME" }}

name: Integration

on:
  pull_request:
    branches:
      - {{ default "MAIN_BRANCH" "main" }}

permissions:
  pull-requests: write
  actions: read
  contents: read

jobs:

  test:
    name: Run Tests
    runs-on: {{ default "RUNNER" "ubuntu-latest" }}
    timeout-minutes: {{ default "TIMEOUT_MINUTES" "10" }}
    steps:
      - uses: elpic/actions/integration/go/test@v1
        with:
          setup: {{ default "SETUP" "mise" }}
          test-coverage-task: {{ default "TEST_TASK" "test:coverage" }}

  lint:
    name: Run Linter
    runs-on: {{ default "RUNNER" "ubuntu-latest" }}
    timeout-minutes: {{ default "TIMEOUT_MINUTES" "10" }}
    steps:
      - uses: elpic/actions/integration/go/lint@v1
        with:
          setup: {{ default "SETUP" "mise" }}
          lint-task: {{ default "LINT_TASK" "lint" }}

  build:
    name: Build Binary
    runs-on: {{ default "RUNNER" "ubuntu-latest" }}
    timeout-minutes: {{ default "TIMEOUT_MINUTES" "10" }}
    steps:
      - uses: actions/checkout@v6
      - uses: jdx/mise-action@v2
      - name: Build
        run: mise run {{ default "BUILD_TASK" "build" }}
      - name: Upload build artifact
        uses: actions/upload-artifact@v4
        with:
          name: {{ var "APP_NAME" }}-binaries
          path: {{ var "APP_NAME" }}-*

  integration:
    name: Integration Tests
    runs-on: {{ default "RUNNER" "ubuntu-latest" }}
    needs: [test, lint, build]
    timeout-minutes: {{ default "TIMEOUT_MINUTES" "10" }}
    steps:
      - uses: elpic/actions/integration/go/integration-tests@v1
        with:
          setup: {{ default "SETUP" "mise" }}
          app-name: {{ var "APP_NAME" }}
          integration-task: {{ default "INTEGRATION_TASK" "test:integration" }}

  security:
    name: Security Checks
    runs-on: {{ default "RUNNER" "ubuntu-latest" }}
    timeout-minutes: {{ default "TIMEOUT_MINUTES" "10" }}
    steps:
      - uses: elpic/actions/integration/go/security@v1
        with:
          setup: {{ default "SETUP" "mise" }}
          security-task: {{ default "SECURITY_TASK" "security" }}
