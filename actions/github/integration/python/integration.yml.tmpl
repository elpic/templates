# Check drift:  blueprint check setup.bp --template . --against .github/workflows

name: Integration

on:
  pull_request:
    branches:
      - {{ default "MAIN_BRANCH" "main" }}

permissions:
  pull-requests: write
  actions: read
  contents: read

jobs:

  test:
    name: Run Tests
    runs-on: {{ default "RUNNER" "ubuntu-latest" }}
    timeout-minutes: {{ default "TIMEOUT_MINUTES" "10" }}
    steps:
      - uses: elpic/actions/integration/python/test@v1
        with:
          test-task: {{ default "TEST_TASK" "test" }}
          test-coverage-task: {{ default "TEST_COVERAGE_TASK" "test:coverage" }}

  lint:
    name: Run Linter
    runs-on: {{ default "RUNNER" "ubuntu-latest" }}
    timeout-minutes: {{ default "TIMEOUT_MINUTES" "10" }}
    steps:
      - uses: elpic/actions/integration/python/lint@v1
        with:
          lint-task: {{ default "LINT_TASK" "lint" }}

  integration:
    name: Integration Tests
    runs-on: {{ default "RUNNER" "ubuntu-latest" }}
    needs: [test, lint]
    timeout-minutes: {{ default "TIMEOUT_MINUTES" "10" }}
    steps:
      - uses: elpic/actions/integration/python/integration-tests@v1
        with:
          integration-task: {{ default "INTEGRATION_TASK" "test:integration" }}

  security:
    name: Security Checks
    runs-on: {{ default "RUNNER" "ubuntu-latest" }}
    timeout-minutes: {{ default "TIMEOUT_MINUTES" "10" }}
    steps:
      - uses: elpic/actions/integration/python/security@v1
        with:
          security-task: {{ default "SECURITY_TASK" "security" }}
