# Generated from setup.bp — do not edit directly.
# Regenerate: blueprint render setup.bp --template . --output .github/workflows --var APP_NAME={{ var "APP_NAME" }}
# Check drift:  blueprint check setup.bp --template . --against .github/workflows --var APP_NAME={{ var "APP_NAME" }}

name: Integration

on:
  pull_request:
    branches:
      - {{ default "MAIN_BRANCH" "main" }}

permissions:
  pull-requests: write
  actions: read
  contents: read

env:
  GH_TOKEN: ${{ "{{" }} secrets.GITHUB_TOKEN {{ "}}" }}

jobs:

  ###########################
  # Tests + coverage        #
  ###########################

  test:
    name: Run Tests
    runs-on: ubuntu-latest
    timeout-minutes: {{ default "TIMEOUT_MINUTES" "10" }}

    steps:
      - name: Checkout code
        uses: actions/checkout@v4
        with:
          fetch-depth: 0

      - name: Install mise
        uses: jdx/mise-action@v2

      - name: Download main branch coverage
        id: download-main-coverage
        run: |
          MAIN_SHA=$(git rev-parse origin/{{ default "MAIN_BRANCH" "main" }})
          echo "main_sha=$MAIN_SHA" >> $GITHUB_OUTPUT
          if gh run download -n "coverage-$MAIN_SHA" --repo ${{ "{{" }} github.repository {{ "}}" }} 2>/dev/null; then
            echo "coverage_available=true" >> $GITHUB_OUTPUT
          else
            echo "coverage_available=false" >> $GITHUB_OUTPUT
          fi

      - name: Run tests without coverage (cached main coverage available)
        if: steps.download-main-coverage.outputs.coverage_available == 'true'
        run: go test ./...

      - name: Run tests with coverage (no cached main coverage)
        if: steps.download-main-coverage.outputs.coverage_available != 'true'
        run: mise run {{ default "TEST_TASK" "test:coverage" }}
        timeout-minutes: 8

      - name: Generate HTML coverage report
        if: hashFiles('coverage.out') != ''
        run: go tool cover -html=coverage.out -o coverage.html

      - name: Upload coverage artifact
        if: hashFiles('coverage.out') != ''
        uses: actions/upload-artifact@v4
        with:
          name: coverage-${{ "{{" }} github.event.pull_request.head.sha {{ "}}" }}
          path: coverage.*

      - name: Calculate current coverage
        id: coverage
        if: hashFiles('coverage.out') != ''
        run: |
          coverage=$(go tool cover -func coverage.out | grep total | awk '{print $3}' | sed 's/%//')
          echo "current_coverage=$coverage" >> $GITHUB_OUTPUT

      - name: Calculate main branch coverage
        id: main-coverage
        if: steps.download-main-coverage.outputs.coverage_available != 'true'
        run: |
          git stash
          git checkout {{ default "MAIN_BRANCH" "main" }}
          mise run {{ default "TEST_TASK" "test:coverage" }} || true
          main_coverage=$(go tool cover -func coverage.out | grep total | awk '{print $3}' | sed 's/%//')
          echo "main_coverage=$main_coverage" >> $GITHUB_OUTPUT
          git checkout -
          git stash pop || true

      - name: Generate coverage report summary
        id: coverage-report
        if: hashFiles('coverage.out') != ''
        run: |
          current="${{ "{{" }} steps.coverage.outputs.current_coverage {{ "}}" }}"
          main="${{ "{{" }} steps.main-coverage.outputs.main_coverage {{ "}}" }}"
          current=${current:-0}
          main=${main:-0}
          diff=$(echo "$current - $main" | bc 2>/dev/null || echo "0")
          echo "current=$current" >> $GITHUB_OUTPUT
          echo "main=$main" >> $GITHUB_OUTPUT
          echo "diff=$diff" >> $GITHUB_OUTPUT

          echo "## Coverage Report" >> $GITHUB_STEP_SUMMARY
          echo "" >> $GITHUB_STEP_SUMMARY
          echo "| Metric | Value |" >> $GITHUB_STEP_SUMMARY
          echo "|--------|-------|" >> $GITHUB_STEP_SUMMARY
          echo "| Current Coverage | ${current}% |" >> $GITHUB_STEP_SUMMARY
          echo "| Main Branch Coverage | ${main}% |" >> $GITHUB_STEP_SUMMARY
          echo "| Difference | ${diff}% |" >> $GITHUB_STEP_SUMMARY
          echo "" >> $GITHUB_STEP_SUMMARY
          if (( $(echo "$diff > 0" | bc -l 2>/dev/null || echo "0") )); then
            echo "✅ Coverage increased by ${diff}%" >> $GITHUB_STEP_SUMMARY
          elif (( $(echo "$diff < 0" | bc -l 2>/dev/null || echo "0") )); then
            echo "⚠️ Coverage decreased by ${diff#-}%" >> $GITHUB_STEP_SUMMARY
          else
            echo "➡️ Coverage unchanged" >> $GITHUB_STEP_SUMMARY
          fi

      - name: Post coverage comment on PR
        if: hashFiles('coverage.out') != ''
        run: |
          current="${{ "{{" }} steps.coverage-report.outputs.current {{ "}}" }}"
          main="${{ "{{" }} steps.coverage-report.outputs.main {{ "}}" }}"
          diff="${{ "{{" }} steps.coverage-report.outputs.diff {{ "}}" }}"
          current=${current:-0}; main=${main:-0}; diff=${diff:-0}

          if (( $(echo "$diff > 0" | bc -l 2>/dev/null || echo "0") )); then
            diff_fmt="+${diff}%"; emoji="📈"
          elif (( $(echo "$diff < 0" | bc -l 2>/dev/null || echo "0") )); then
            diff_fmt="${diff}%"; emoji="📉"
          else
            diff_fmt="unchanged"; emoji="➡️"
          fi

          low_coverage=$(go tool cover -func coverage.out | grep -v "total:" | \
            awk -F'[\t:]' '{
              split($2,pct,"%")
              if (pct[1] < 50 && pct[1] > 0) {
                path=$1; n=split(path,parts,"/"); file=parts[n]
                if (!(file in min) || pct[1]<min[file]) { min[file]=pct[1]; paths[file]=path }
              }
            } END {
              for (file in min) printf "| %3d%% | %s |\n", min[file], paths[file]
            }' | sort -t'|' -k2 -n | head -10)

          COMMENT="## Coverage Report ${emoji}

          | Metric | Value |
          |--------|-------|
          | **This PR** | ${current}% |
          | **Main Branch** | ${main}% |
          | **Change** | ${diff_fmt} ${emoji} |"

          if [ -n "$low_coverage" ]; then
            COMMENT="${COMMENT}

          ### Files Needing Coverage

          | Coverage | File |
          |----------|------|
          ${low_coverage}"
          fi

          PR_NUMBER=${{ "{{" }} github.event.pull_request.number {{ "}}" }}
          COMMENT_ID=$(gh api repos/${{ "{{" }} github.repository {{ "}}" }}/issues/${PR_NUMBER}/comments \
            --jq '.[] | select(.body | startswith("## Coverage Report")) | .id' 2>/dev/null | head -1)
          if [ -n "$COMMENT_ID" ]; then
            gh api repos/${{ "{{" }} github.repository {{ "}}" }}/issues/comments/${COMMENT_ID} \
              --method PATCH --field body="${COMMENT}"
          else
            gh pr comment ${PR_NUMBER} --body "${COMMENT}"
          fi

  ###########################
  # Lint                    #
  ###########################

  lint:
    name: Run Linter
    runs-on: ubuntu-latest
    timeout-minutes: {{ default "TIMEOUT_MINUTES" "10" }}

    steps:
      - name: Checkout code
        uses: actions/checkout@v4

      - name: Install mise
        uses: jdx/mise-action@v2

      - name: Run linter
        run: mise run {{ default "LINT_TASK" "lint" }}

  ###########################
  # Build                   #
  ###########################

  build:
    name: Build Binary
    runs-on: ubuntu-latest
    timeout-minutes: {{ default "TIMEOUT_MINUTES" "10" }}

    steps:
      - name: Checkout code
        uses: actions/checkout@v4

      - name: Install mise
        uses: jdx/mise-action@v2

      - name: Build
        run: mise run {{ default "BUILD_TASK" "build" }}

      - name: Upload build artifact
        uses: actions/upload-artifact@v4
        with:
          name: {{ var "APP_NAME" }}-binaries
          path: {{ var "APP_NAME" }}-*

  ###########################
  # Integration tests       #
  ###########################

  integration:
    name: Integration Tests
    runs-on: ubuntu-latest
    needs: [test, lint, build]
    timeout-minutes: {{ default "TIMEOUT_MINUTES" "10" }}

    steps:
      - name: Checkout code
        uses: actions/checkout@v4

      - name: Install mise
        uses: jdx/mise-action@v2

      - name: Download build artifact
        uses: actions/download-artifact@v4
        with:
          name: {{ var "APP_NAME" }}-binaries

      - name: Make binaries executable
        run: chmod +x {{ var "APP_NAME" }}-*

      - name: Run integration tests
        run: mise run {{ default "INTEGRATION_TASK" "test:integration" }}

  ###########################
  # Security                #
  ###########################

  security:
    name: Security Checks
    runs-on: ubuntu-latest
    timeout-minutes: {{ default "TIMEOUT_MINUTES" "10" }}

    steps:
      - name: Checkout code
        uses: actions/checkout@v4

      - name: Install mise
        uses: jdx/mise-action@v2

      - name: Run security scan
        run: mise run security
