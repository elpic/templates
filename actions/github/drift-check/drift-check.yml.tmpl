name: Drift Check

on:
  pull_request:
    branches:
      - {{ default "MAIN_BRANCH" "main" }}

permissions:
  pull-requests: write
  contents: read

jobs:

  drift-check:
    name: Drift Check
    runs-on: {{ default "RUNNER" "ubuntu-latest" }}
    timeout-minutes: {{ default "TIMEOUT_MINUTES" "10" }}

    steps:
{{ range toValue "CHECKS" }}
      - name: 'Check {{ .file }}'
        uses: elpic/actions/github/drift-check@{{ default "ACTIONS_VERSION" "v2" }}
        with:
          blueprint-file: '{{ .file }}'
          template: '{{ .template }}'
          against: '{{ .against }}'
{{ end }}
