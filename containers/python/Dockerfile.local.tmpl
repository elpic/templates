# syntax=docker/dockerfile:1
# Generated from setup.bp — do not edit directly.
# Regenerate: blueprint render setup.bp --template . --output . --var APP_NAME={{ var "APP_NAME" }}
# Check drift:  blueprint check setup.bp --template . --against . --var APP_NAME={{ var "APP_NAME" }}

###########################
# Build arguments         #
###########################
ARG PYTHON_VERSION={{ mise "python" }}
ARG UV_VERSION={{ default "UV_VERSION" "latest" }}
ARG REGISTRY={{ default "REGISTRY" "docker.io" }}
ARG WORKDIR={{ default "WORKDIR" "/app" }}

FROM ${REGISTRY}/python:${PYTHON_VERSION}-slim

ARG UV_VERSION
ARG WORKDIR

LABEL maintainer="{{ var "APP_NAME" }}"

###########################
# Process manager         #
###########################
# Install uv — fast Python package manager
COPY --from=ghcr.io/astral-sh/uv:${UV_VERSION} /uv /uvx /usr/local/bin/

###########################
# System dependencies     #
###########################
# Install all system packages (build + runtime) — dev image, no size restriction
RUN apt-get update && apt-get install -y --no-install-recommends \
    {{ packages }} \
    && rm -rf /var/lib/apt/lists/*

ENV UV_LINK_MODE=copy \
    UV_COMPILE_BYTECODE=1 \
    UV_NO_PROGRESS=1 \
    UV_NO_MANAGED_PYTHON=1 \
    UV_PYTHON_DOWNLOADS=never \
    PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1

###########################
# Set working directory   #
###########################
WORKDIR ${WORKDIR}

###########################
# Manifest files          #
###########################
# Install all dependencies including dev — bind-mount lockfiles to avoid extra layer.
# Application code is volume-mounted at runtime — no COPY needed.
RUN --mount=type=cache,target=/root/.cache/uv \
    --mount=type=bind,source=uv.lock,target=uv.lock \
    --mount=type=bind,source=pyproject.toml,target=pyproject.toml \
    uv sync --frozen --no-install-project

###########################
# Run the app             #
###########################
EXPOSE {{ default "PORT" "8000" }}

# No entrypoint script in dev — run commands directly via docker-compose.
# Default: python -m <APP_NAME>. Override with --var CMD="uvicorn myapp.main:app --reload"
CMD {{ default "CMD" (printf "python -m %s" (var "APP_NAME")) | toArgs }}
