# syntax=docker/dockerfile:1
# Generated from setup.bp — do not edit directly.
# Regenerate: blueprint render setup.bp --template Dockerfile.tmpl --var APP_NAME={{ var "APP_NAME" }} --output Dockerfile
# Check drift: blueprint check setup.bp --template Dockerfile.tmpl --against Dockerfile --var APP_NAME={{ var "APP_NAME" }}

# ── Stage 1: dependencies ────────────────────────────────────────────────────
FROM {{ var "REGISTRY" }}/python:{{ mise "python" }}-slim AS deps

# Install uv
COPY --from=ghcr.io/astral-sh/uv:{{ var "UV_VERSION" }} /uv /usr/local/bin/uv

ENV UV_LINK_MODE=copy \
    UV_COMPILE_BYTECODE=1 \
    UV_NO_CACHE=1

WORKDIR {{ var "WORKDIR" }}

# Install dependencies only — layer is cached until lockfile changes
COPY pyproject.toml uv.lock ./
RUN --mount=type=cache,target=/root/.cache/uv \
    uv sync --frozen --no-install-project --no-dev

# ── Stage 2: build ───────────────────────────────────────────────────────────
FROM {{ var "REGISTRY" }}/python:{{ mise "python" }}-slim AS build

COPY --from=ghcr.io/astral-sh/uv:{{ var "UV_VERSION" }} /uv /usr/local/bin/uv

ENV UV_LINK_MODE=copy \
    UV_COMPILE_BYTECODE=1 \
    UV_NO_CACHE=1

WORKDIR {{ var "WORKDIR" }}

# Copy deps from previous stage then install the project itself
COPY --from=deps {{ var "WORKDIR" }}/.venv .venv
COPY . .
RUN --mount=type=cache,target=/root/.cache/uv \
    uv sync --frozen --no-dev

# ── Stage 3: runtime ─────────────────────────────────────────────────────────
FROM {{ var "REGISTRY" }}/python:{{ mise "python" }}-slim AS runtime

RUN apt-get update && apt-get install -y --no-install-recommends \
    {{ packages }} \
    && rm -rf /var/lib/apt/lists/* \
    && apt-get purge -y --auto-remove

# Non-root user for security
RUN groupadd --gid 1001 app && useradd --uid 1001 --gid app --shell /bin/bash --create-home app

WORKDIR {{ var "WORKDIR" }}

# Copy only the built virtualenv and app code — no build tools in final image
COPY --from=build --chown=app:app {{ var "WORKDIR" }}/.venv .venv
COPY --from=build --chown=app:app {{ var "WORKDIR" }} .

USER app

ENV PATH="{{ var "WORKDIR" }}/.venv/bin:$PATH" \
    PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PYTHONFAULTHANDLER=1

EXPOSE {{ var "PORT" }}

HEALTHCHECK --interval=30s --timeout=5s --start-period=10s --retries=3 \
    CMD python -c "import urllib.request; urllib.request.urlopen('http://localhost:{{ var "PORT" }}/health')"

ENTRYPOINT ["{{ var "ENTRYPOINT" }}"]
CMD ["-m", "{{ var "APP_NAME" }}"]
