# syntax=docker/dockerfile:1
# Generated from setup.bp — do not edit directly.
# Regenerate: blueprint render setup.bp --template Dockerfile.tmpl --var APP_NAME={{ var "APP_NAME" }} --output Dockerfile
# Check drift:  blueprint check setup.bp --template Dockerfile.tmpl --against Dockerfile --var APP_NAME={{ var "APP_NAME" }}

# ── Build arguments (override with --build-arg) ───────────────────────────────
# These are build-time only and do not leak into the final image.
ARG PYTHON_VERSION={{ mise "python" }}
ARG UV_VERSION={{ default "UV_VERSION" "latest" }}
ARG REGISTRY={{ default "REGISTRY" "docker.io" }}
ARG WORKDIR={{ default "WORKDIR" "/app" }}

# ── Stage 1: dependencies ─────────────────────────────────────────────────────
FROM ${REGISTRY}/python:${PYTHON_VERSION}-slim AS deps

ARG UV_VERSION
ARG WORKDIR

COPY --from=ghcr.io/astral-sh/uv:${UV_VERSION} /uv /uvx /usr/local/bin/

ENV UV_LINK_MODE=copy \
    UV_COMPILE_BYTECODE=1 \
    UV_NO_PROGRESS=1

WORKDIR ${WORKDIR}

# Install only production dependencies — bind-mount lockfiles so they don't
# create an extra layer. Layer is fully cached until pyproject.toml/uv.lock change.
RUN --mount=type=cache,target=/root/.cache/uv \
    --mount=type=bind,source=uv.lock,target=uv.lock \
    --mount=type=bind,source=pyproject.toml,target=pyproject.toml \
    uv sync --frozen --no-install-project --no-dev

# ── Stage 2: runtime ──────────────────────────────────────────────────────────
FROM ${REGISTRY}/python:${PYTHON_VERSION}-slim AS runtime

ARG WORKDIR

# Install only runtime system packages — no build tools
RUN apt-get update && apt-get install -y --no-install-recommends \
    {{ packages }} \
    && rm -rf /var/lib/apt/lists/*

# Non-root user — uid/gid 1001 avoids conflicts with common system users
RUN groupadd --gid 1001 app \
    && useradd --uid 1001 --gid app --shell /bin/bash --no-create-home app

WORKDIR ${WORKDIR}

# Copy virtualenv from deps stage and application code
COPY --from=deps --chown=app:app ${WORKDIR}/.venv .venv
COPY --chown=app:app . .

USER app

ENV PATH="${WORKDIR}/.venv/bin:$PATH" \
    PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PYTHONFAULTHANDLER=1 \
    PYTHONHASHSEED=random

# OCI image labels
LABEL org.opencontainers.image.title="{{ var "APP_NAME" }}" \
      org.opencontainers.image.source="" \
      org.opencontainers.image.licenses=""

EXPOSE {{ default "PORT" "8000" }}

# Increase start-period to allow for migrations, warm-up, etc.
HEALTHCHECK --interval=30s --timeout=5s --start-period=120s --retries=3 \
    CMD python -c "import urllib.request; urllib.request.urlopen('http://localhost:{{ default "PORT" "8000" }}/health')"

ENTRYPOINT ["{{ default "ENTRYPOINT" "python" }}"]
CMD ["-m", "{{ var "APP_NAME" }}"]
