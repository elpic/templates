# syntax=docker/dockerfile:1
# Generated from setup.bp — do not edit directly.
# Regenerate: blueprint render setup.bp --template . --output . --var APP_NAME={{ var "APP_NAME" }}
# Check drift:  blueprint check setup.bp --template . --against . --var APP_NAME={{ var "APP_NAME" }}

###########################
# Build arguments         #
###########################
ARG NODE_VERSION={{ var "NODE_VERSION" }}
ARG REGISTRY={{ default "REGISTRY" "docker.io" }}
ARG WORKDIR={{ default "WORKDIR" "/app" }}

FROM ${REGISTRY}/node:${NODE_VERSION}-slim

ARG WORKDIR

LABEL maintainer="{{ var "APP_NAME" }}"

###########################
# System dependencies     #
###########################

# Install all system packages (build + runtime) — dev image, no size restriction
RUN apt-get update && apt-get install -y --no-install-recommends \
    {{ packages }} \
    && rm -rf /var/lib/apt/lists/*

ENV NODE_ENV=development

###########################
# Set working directory   #
###########################

WORKDIR ${WORKDIR}

###########################
# Manifest files          #
###########################

# Install all dependencies including dev — bind-mount manifest files to avoid
# extra layer. Application code is volume-mounted at runtime — no COPY needed.
RUN --mount=type=cache,target=/root/.npm \
    --mount=type=bind,source=package.json,target=package.json \
    --mount=type=bind,source=package-lock.json,target=package-lock.json \
    npm ci

###########################
# Run the app             #
###########################

# local-entrypoint.sh is available from the host via volume mount at runtime.
# It installs deps and runs pre-start tasks then execs CMD.

EXPOSE {{ default "PORT" "3000" }}

# Default: npx tsx watch src/index.ts. Override with --var CMD="npx tsx watch src/server.ts"
ENTRYPOINT ["./local-entrypoint.sh"]
CMD {{ default "CMD" "npx tsx watch src/index.ts" | toArgs }}
