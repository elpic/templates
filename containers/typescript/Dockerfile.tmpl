# syntax=docker/dockerfile:1
# Generated from setup.bp — do not edit directly.
# Regenerate: blueprint render setup.bp --template . --output . --var APP_NAME={{ var "APP_NAME" }}
# Check drift:  blueprint check setup.bp --template . --against . --var APP_NAME={{ var "APP_NAME" }}

###########################
# Build arguments         #
###########################
# These are build-time only and do not leak into the final image.
ARG NODE_VERSION={{ var "NODE_VERSION" }}
ARG REGISTRY={{ default "REGISTRY" "docker.io" }}
ARG WORKDIR={{ default "WORKDIR" "/app" }}

###########################
# Stage 1: build          #
###########################

FROM ${REGISTRY}/node:${NODE_VERSION}-slim AS build

ARG WORKDIR

LABEL maintainer="{{ var "APP_NAME" }}"

# Install build-only system packages — not present in the final image
RUN apt-get update && apt-get install -y --no-install-recommends \
    {{ packages "" "build" }} \
    && rm -rf /var/lib/apt/lists/*

# Set working directory
WORKDIR ${WORKDIR}

# Install all dependencies (including devDependencies) — bind-mount manifest files
# so they don't create an extra layer. Layer is fully cached until
# package.json/package-lock.json change.
RUN --mount=type=cache,target=/root/.npm \
    --mount=type=bind,source=package.json,target=package.json \
    --mount=type=bind,source=package-lock.json,target=package-lock.json \
    npm ci

# Build TypeScript — assumes "build" script in package.json runs tsc
COPY . .
RUN npm run build

###########################
# Stage 2: runtime        #
###########################

FROM ${REGISTRY}/node:${NODE_VERSION}-slim AS runtime

ARG WORKDIR

ENV NODE_ENV=production

# Install only runtime system packages — no build tools
RUN apt-get update && apt-get install -y --no-install-recommends \
    {{ packages "" "runtime" }} \
    && rm -rf /var/lib/apt/lists/*

# Non-root user — uid/gid 1001 avoids conflicts with common system users
RUN groupadd --gid 1001 app \
    && useradd --uid 1001 --gid app --shell /bin/bash --no-create-home app

# Set working directory
WORKDIR ${WORKDIR}

# Copy compiled output from build stage
COPY --from=build --chown=app:app ${WORKDIR}/dist ./dist

# Copy package manifests and install production dependencies only
COPY --from=build --chown=app:app ${WORKDIR}/package*.json ./
RUN --mount=type=cache,target=/root/.npm \
    npm ci --omit=dev --ignore-scripts

# entrypoint.sh runs pre-start tasks then execs CMD
COPY --chown=app:app entrypoint.sh .
RUN chmod +x entrypoint.sh

USER app

ENV PATH="${WORKDIR}/node_modules/.bin:$PATH" \
    NODE_ENV=production

###########################
# Metadata                #
###########################

# OCI image labels
LABEL org.opencontainers.image.title="{{ var "APP_NAME" }}" \
      org.opencontainers.image.source="" \
      org.opencontainers.image.licenses=""

###########################
# Run the app             #
###########################

EXPOSE {{ default "PORT" "3000" }}

# Increase start-period to allow for migrations, warm-up, etc.
# Override interval, timeout, start-period, or retries via --var HC_*.
HEALTHCHECK --interval={{ default "HC_INTERVAL" "30s" }} --timeout={{ default "HC_TIMEOUT" "5s" }} --start-period={{ default "HC_START_PERIOD" "120s" }} --retries={{ default "HC_RETRIES" "3" }} \
    CMD wget --no-verbose --tries=1 --spider http://localhost:{{ default "PORT" "3000" }}/health || exit 1

# entrypoint.sh handles pre-start tasks; CMD is the actual application command.
# Default: node dist/index.js. Override with --var CMD="node dist/server.js"
ENTRYPOINT ["./entrypoint.sh"]
CMD {{ default "CMD" "node dist/index.js" | toArgs }}
